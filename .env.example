# ── Segurança ─────────────────────────────────────────────────────────────────
# Token secreto compartilhado com a Vercel (gere com: openssl rand -hex 32)
INTERNAL_API_TOKEN=token-secreto

# Domínios permitidos no CORS (separados por vírgula, sem espaço)
# Use o domínio exato do seu frontend (ex: https://meu-projeto.vercel.app)
ALLOWED_ORIGINS=https://meu-projeto.vercel.app,localhost:3000,http://localhost:8000

# ── Cookies do YouTube ────────────────────────────────────────────────────────
# Caminho dentro do container (montado via volume no docker-compose)
YT_DLP_COOKIEFILE=/app/cookies.txt

# ── Runtime JS para yt-dlp ────────────────────────────────────────────────────
YT_DLP_JS_RUNTIME=node

# ── Componentes remotos yt-dlp (EJS) ─────────────────────────────────────────
# 1 = habilitado (padrão), 0 = desabilitado
YT_DLP_REMOTE_EJS=1

# ── Ajustes de extração YouTube (anti-429 / anti-PO warning) ─────────────────
# Clientes usados pelo extractor (evite android sem PO token)
YT_DLP_PLAYER_CLIENTS=web
# Pular etapas mais suscetíveis a 429 no webpage
YT_DLP_PLAYER_SKIP=webpage
# Pequeno jitter entre requests internos do yt-dlp
YT_DLP_SLEEP_INTERVAL_REQUESTS=0.5
YT_DLP_MAX_SLEEP_INTERVAL_REQUESTS=1.5
