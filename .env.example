# ── Segurança ─────────────────────────────────────────────────────────────────
# Token secreto compartilhado com a Vercel (gere com: openssl rand -hex 32)
INTERNAL_API_TOKEN=token-secreto

# Domínios permitidos no CORS (separados por vírgula, sem espaço)
# Use o domínio exato do seu frontend (ex: https://meu-projeto.vercel.app)
ALLOWED_ORIGINS=https://meu-projeto.vercel.app,localhost:3000,http://localhost:8000

# ── Redis para rate limit distribuído ────────────────────────────────────────
# Em docker-compose local, o default já aponta para o serviço "redis".
# Em produção, aponte para seu Redis gerenciado.
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=180

# ── Fila assíncrona de downloads de áudio (RQ) ───────────────────────────────
AUDIO_QUEUE_NAME=audio-downloads
AUDIO_JOB_TIMEOUT_SECONDS=900
AUDIO_RESULT_TTL_SECONDS=3600
AUDIO_FAILURE_TTL_SECONDS=86400

# ── Cookies do YouTube ────────────────────────────────────────────────────────
# Caminho dentro do container (montado via volume no docker-compose)
YT_DLP_COOKIEFILE=/app/cookies.txt
# Alternativa para plataformas sem volume (Railway): passe o arquivo Netscape em base64
# Ex: base64 -w0 cookies.txt
YT_DLP_COOKIES_B64=
# Alternativa textual (com \n escapado). Prefira YT_DLP_COOKIES_B64.
YT_DLP_COOKIES_RAW=

# ── Runtime JS para yt-dlp ────────────────────────────────────────────────────
YT_DLP_JS_RUNTIME=node

# ── Componentes remotos yt-dlp (EJS) ─────────────────────────────────────────
# 1 = habilitado (padrão), 0 = desabilitado
YT_DLP_REMOTE_EJS=1

# ── Ajustes de extração YouTube (anti-429 / anti-PO warning) ─────────────────
# Clientes usados pelo extractor (ordem importa)
# Em 2026, ios/mweb/tv costumam ser mais estáveis que apenas web.
YT_DLP_PLAYER_CLIENTS=ios,mweb,tv,web
# Fallback quando houver 403 durante o download
YT_DLP_PLAYER_CLIENTS_FALLBACK=mweb,tv,ios,web
# Pular etapas mais suscetíveis a 429 no webpage
YT_DLP_PLAYER_SKIP=webpage

# ── Performance de download ──────────────────────────────────────────────────
# 0 desabilita limite de velocidade. Para reproduzir o limite antigo:
# YT_DLP_RATELIMIT_BYTES=1048576
YT_DLP_RATELIMIT_BYTES=0
# 0 desabilita a detecção de throttling por taxa mínima.
YT_DLP_THROTTLED_RATELIMIT_BYTES=0
# Downloads fragmentados em paralelo (bom ganho para YouTube DASH/HLS).
YT_DLP_CONCURRENT_FRAGMENT_DOWNLOADS=4
# Jitter opcional entre requests internos do yt-dlp. 0 = sem atraso artificial.
YT_DLP_SLEEP_INTERVAL_REQUESTS=0
YT_DLP_MAX_SLEEP_INTERVAL_REQUESTS=0
# Espera opcional antes de iniciar o download e entre retries de 403.
YT_DLP_PRE_DOWNLOAD_SLEEP_MIN=0
YT_DLP_PRE_DOWNLOAD_SLEEP_MAX=0
YT_DLP_RETRY_SLEEP_MIN=0.2
YT_DLP_RETRY_SLEEP_MAX=0.6
